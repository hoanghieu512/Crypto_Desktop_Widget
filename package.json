{
  "name": "crypto-desktop-widget",
  "private": true,
  "version": "1.7.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dist:mac": "npm run build && electron-builder --mac --x64",
    "electron": "electron .",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && ELECTRON_DEV=1 electron .\"",
    "dev:electron:5174": "concurrently -k \"vite --port 5174\" \"wait-on http://127.0.0.1:5174 && ELECTRON_DEV=1 VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .\"",
    "electron:attach": "node scripts/electron-attach.mjs",
    "electron:attach:5174": "VITE_DEV_PORT=5174 node scripts/electron-attach.mjs",
    "electron:dev": "npm run dev:electron",
    "electron:start": "electron .",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.cryptodesktopwidget.app",
    "productName": "Crypto Desktop Widget",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64"] }
      ],
      "category": "public.app-category.finance"
    },
    "dmg": {
      "title": "${productName} ${version}"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
